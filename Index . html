<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Confession Booth MCR — Alternative Nail Studio Manchester</title>
<meta name="description" content="Manchester's female-owned alternative nail studio. Goth glam, Y2K chaos, BIAB, junk nails & custom hand-painted art. Vegan & cruelty-free. Book direct.">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --black: #080808;
  --charcoal: #101010;
  --card: #141414;
  --pink: #ff1a6e;
  --pink-glow: rgba(255,26,110,0.35);
  --burgundy: #5c0a15;
  --neon-green: #39ff14;
  --chrome: #b8b8b8;
  --gold: #d4a843;
  --white: #f0eaea;
  --muted: #666;
  --border: rgba(255,255,255,0.07);
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { background:var(--black); color:var(--white); font-family:'Inter',sans-serif; overflow-x:hidden; cursor:default; }

/* SCROLLBAR */
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:var(--black); }
::-webkit-scrollbar-thumb { background:var(--pink); border-radius:2px; }

/* NAV */
nav {
  position:fixed; top:0; width:100%; z-index:999;
  background:rgba(8,8,8,0.95); backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(255,26,110,0.2);
  padding:0 48px; height:68px;
  display:flex; align-items:center; justify-content:space-between;
}
.nav-logo {
  font-family:'Bebas Neue',sans-serif; font-size:1.5rem;
  color:var(--white); letter-spacing:4px; text-decoration:none;
  display:flex; align-items:center; gap:10px;
}
.nav-logo span { color:var(--pink); }
.nav-links { display:flex; gap:36px; list-style:none; align-items:center; }
.nav-links a {
  color:var(--chrome); text-decoration:none; font-size:0.72rem;
  letter-spacing:3px; text-transform:uppercase; transition:color 0.2s;
}
.nav-links a:hover { color:var(--pink); }
.nav-book {
  background:var(--pink); color:#fff; padding:10px 24px;
  font-size:0.68rem; letter-spacing:3px; text-transform:uppercase;
  font-weight:600; text-decoration:none; border-radius:2px;
  transition:all 0.2s; white-space:nowrap;
}
.nav-book:hover { background:#ff4d8f; box-shadow:0 0 20px var(--pink-glow); }

/* HERO */
.hero {
  min-height:100vh; display:flex; flex-direction:column;
  justify-content:flex-end; align-items:flex-start;
  padding:0 80px 100px; position:relative; overflow:hidden;
}
.hero-bg {
  position:absolute; inset:0; z-index:0;
  background:
    radial-gradient(ellipse 100% 70% at 50% -10%, rgba(255,26,110,0.22) 0%, transparent 65%),
    radial-gradient(ellipse 60% 50% at 90% 90%, rgba(92,10,21,0.4) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 10% 60%, rgba(57,255,20,0.04) 0%, transparent 55%),
    linear-gradient(180deg, #080808 0%, #0d0508 100%);
}
.hero-noise {
  position:absolute; inset:0; z-index:1; opacity:0.03;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}
.hero-content { position:relative; z-index:2; max-width:900px; }

.hero-eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  border:1px solid rgba(255,26,110,0.35); color:var(--pink);
  font-size:0.65rem; letter-spacing:5px; text-transform:uppercase;
  padding:8px 18px; border-radius:100px; margin-bottom:36px;
  background:rgba(255,26,110,0.06);
}
.hero-eyebrow::before { content:'⚔'; font-size:0.75rem; }

.hero h1 {
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(5rem, 14vw, 13rem);
  line-height:0.9; letter-spacing:6px;
  color:var(--white); margin-bottom:8px;
}
.hero h1 .pink { color:var(--pink); }
.hero h1 .outline {
  -webkit-text-stroke:2px rgba(255,255,255,0.25);
  color:transparent;
}

.hero-tagline {
  font-family:'Playfair Display', serif; font-style:italic;
  font-size:clamp(1rem, 2.2vw, 1.5rem);
  color:rgba(240,234,234,0.55); margin-bottom:48px;
  letter-spacing:1px;
}

.hero-actions { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:56px; }

.btn-sin {
  background:var(--pink); color:#fff; padding:18px 48px;
  font-family:'Bebas Neue',sans-serif; font-size:1.1rem;
  letter-spacing:4px; text-decoration:none; border-radius:2px;
  transition:all 0.25s; border:none; cursor:pointer; display:inline-block;
}
.btn-sin:hover { background:#ff4d8f; box-shadow:0 8px 40px var(--pink-glow); transform:translateY(-2px); }

.btn-outline {
  background:transparent; color:var(--white);
  border:1px solid rgba(255,255,255,0.2); padding:18px 48px;
  font-family:'Bebas Neue',sans-serif; font-size:1.1rem;
  letter-spacing:4px; text-decoration:none; border-radius:2px;
  transition:all 0.25s; display:inline-block;
}
.btn-outline:hover { border-color:var(--pink); color:var(--pink); }

.hero-tags { display:flex; gap:10px; flex-wrap:wrap; }
.htag {
  font-size:0.63rem; letter-spacing:2px; text-transform:uppercase;
  padding:6px 14px; border-radius:100px; border:1px solid var(--border);
  color:var(--muted);
}
.htag.v { border-color:rgba(57,255,20,0.25); color:var(--neon-green); }
.htag.p { border-color:rgba(255,26,110,0.3); color:var(--pink); }

/* MARQUEE */
.marquee-wrap {
  overflow:hidden; background:var(--pink); padding:14px 0;
  border-top:none; border-bottom:none;
}
.marquee-track {
  display:flex; width:max-content;
  animation:marquee 22s linear infinite;
}
.marquee-track span {
  font-family:'Bebas Neue',sans-serif; font-size:1rem;
  letter-spacing:5px; color:#fff; white-space:nowrap;
  padding:0 32px;
}
.marquee-track .dot { color:rgba(255,255,255,0.4); }
@keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }

/* SECTION BASE */
.section { padding:110px 80px; max-width:1400px; margin:0 auto; }
.s-label {
  font-size:0.62rem; letter-spacing:6px; text-transform:uppercase;
  color:var(--pink); margin-bottom:14px; display:flex; align-items:center; gap:10px;
}
.s-label::before { content:''; width:24px; height:1px; background:var(--pink); display:block; }
h2.heading {
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2.5rem, 5vw, 4.5rem);
  letter-spacing:4px; line-height:1; margin-bottom:24px;
}

/* DIVIDER */
.line { width:100%; height:1px; background:linear-gradient(90deg, transparent, rgba(255,26,110,0.3), transparent); }

/* ABOUT */
.about-grid { display:grid; grid-template-columns:1fr 1.1fr; gap:100px; align-items:center; }
.about-text p { color:rgba(240,234,234,0.6); line-height:1.9; font-size:0.95rem; margin-bottom:18px; }
.about-pills { display:flex; gap:12px; flex-wrap:wrap; margin-top:32px; }
.pill {
  padding:8px 20px; border-radius:100px; font-size:0.68rem;
  letter-spacing:2px; text-transform:uppercase;
}
.pill.green { background:rgba(57,255,20,0.08); border:1px solid rgba(57,255,20,0.25); color:var(--neon-green); }
.pill.pink { background:rgba(255,26,110,0.08); border:1px solid rgba(255,26,110,0.3); color:var(--pink); }
.pill.chrome { background:rgba(184,184,184,0.06); border:1px solid rgba(184,184,184,0.2); color:var(--chrome); }

.stats-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:2px; margin-top:48px; }
.stat {
  background:var(--card); padding:32px 28px;
  border:1px solid var(--border); transition:border-color 0.3s;
}
.stat:hover { border-color:rgba(255,26,110,0.25); }
.stat-n {
  font-family:'Bebas Neue',sans-serif; font-size:3rem;
  color:var(--pink); letter-spacing:2px; line-height:1;
  margin-bottom:6px; display:block;
}
.stat-l { font-size:0.65rem; letter-spacing:3px; text-transform:uppercase; color:var(--muted); }

.about-right { position:relative; }
.about-img-card {
  background:var(--card); border:1px solid rgba(255,26,110,0.15);
  border-radius:4px; overflow:hidden; position:relative;
}
.about-img-placeholder {
  aspect-ratio:4/5; background:linear-gradient(135deg, #0d0008 0%, #1a0010 30%, #2d0020 60%, #1a0010 100%);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  font-size:6rem; color:rgba(255,26,110,0.3);
}
.about-img-caption {
  padding:20px 24px; font-size:0.72rem; letter-spacing:2px;
  text-transform:uppercase; color:var(--muted);
  border-top:1px solid var(--border);
}
.about-float {
  position:absolute; bottom:-20px; right:-20px;
  background:var(--pink); padding:20px 24px; border-radius:4px;
}
.about-float-text {
  font-family:'Bebas Neue',sans-serif; font-size:1.1rem;
  letter-spacing:3px; color:#fff;
}

/* SERVICES */
.services-bg { background:var(--charcoal); }
.services-bg .section { max-width:1400px; }
.services-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; margin-top:64px; background:var(--border); border:1px solid var(--border); }
.srv {
  background:var(--charcoal); padding:44px 36px;
  transition:background 0.3s; position:relative; overflow:hidden;
}
.srv::before {
  content:''; position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg, var(--pink), var(--burgundy));
  transform:scaleX(0); transform-origin:left; transition:transform 0.4s;
}
.srv:hover { background:#161616; }
.srv:hover::before { transform:scaleX(1); }
.srv-icon { font-size:2.2rem; margin-bottom:20px; display:block; }
.srv h3 { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:3px; margin-bottom:12px; }
.srv p { color:var(--muted); font-size:0.82rem; line-height:1.8; margin-bottom:28px; }
.srv-price { font-family:'Bebas Neue',sans-serif; font-size:1.4rem; color:var(--pink); letter-spacing:2px; }
.srv-tag { font-size:0.6rem; letter-spacing:2px; text-transform:uppercase; color:var(--muted); margin-left:8px; }

/* GALLERY */
.gallery-filters {
  display:flex; gap:10px; flex-wrap:wrap; margin-top:48px; margin-bottom:32px;
}
.gf-btn {
  padding:8px 20px; border-radius:100px; font-size:0.65rem; letter-spacing:2px;
  text-transform:uppercase; border:1px solid var(--border); color:var(--muted);
  background:transparent; cursor:pointer; transition:all 0.2s; font-family:'Inter',sans-serif;
}
.gf-btn.active, .gf-btn:hover {
  border-color:var(--pink); color:var(--pink); background:rgba(255,26,110,0.08);
}
.masonry {
  columns:3; gap:12px; column-gap:12px;
}
.masonry-item {
  break-inside:avoid; margin-bottom:12px;
  border-radius:6px; overflow:hidden; cursor:pointer;
  position:relative; transition:transform 0.3s;
}
.masonry-item:hover { transform:scale(1.02); }
.masonry-item:hover .gallery-overlay { opacity:1; }
.gallery-tile {
  width:100%; display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  font-size:3rem; background:var(--card); border:1px solid var(--border);
}
.gallery-tile.tall { height:380px; }
.gallery-tile.short { height:220px; }
.gallery-tile.med { height:300px; }
.gt1 { background:linear-gradient(160deg,#0d0000,#2a0010,#1a0008); }
.gt2 { background:linear-gradient(160deg,#000010,#10003a,#200060); }
.gt3 { background:linear-gradient(160deg,#080808,#1a0010,#3d0030); }
.gt4 { background:linear-gradient(160deg,#100000,#3d0000,#1a0000); }
.gt5 { background:linear-gradient(160deg,#001000,#003010,#005020); }
.gt6 { background:linear-gradient(160deg,#100010,#2d0040,#4d0080); }
.gt7 { background:linear-gradient(160deg,#1a0a00,#3d2000,#5a3000); }
.gt8 { background:linear-gradient(160deg,#000a10,#001a30,#002a50); }
.gallery-overlay {
  position:absolute; inset:0;
  background:linear-gradient(0deg, rgba(0,0,0,0.8) 0%, transparent 60%);
  opacity:0; transition:opacity 0.3s;
  display:flex; align-items:flex-end; padding:20px;
}
.gallery-ol-text { font-size:0.65rem; letter-spacing:2px; text-transform:uppercase; color:var(--chrome); }

/* TESTIMONIALS */
.testi-bg { background:var(--charcoal); }
.testi-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-top:64px; }
.testi-card {
  background:var(--black); border:1px solid var(--border);
  border-radius:4px; padding:32px 28px; position:relative;
  transition:border-color 0.3s;
}
.testi-card:hover { border-color:rgba(255,26,110,0.25); }
.testi-quote {
  font-family:'Playfair Display',serif; font-style:italic;
  font-size:0.92rem; color:rgba(240,234,234,0.75);
  line-height:1.8; margin-bottom:24px;
}
.testi-quote::before { content:'"'; color:var(--pink); font-size:2rem; line-height:0; vertical-align:-0.5rem; margin-right:4px; }
.testi-stars { color:var(--pink); font-size:0.85rem; margin-bottom:12px; letter-spacing:2px; }
.testi-author { font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:var(--muted); }

/* BOOKING */
.booking-section {
  text-align:center; padding:130px 80px;
  background:linear-gradient(180deg, var(--black) 0%, rgba(92,10,21,0.12) 50%, var(--black) 100%);
  position:relative; overflow:hidden;
}
.booking-cross {
  position:absolute; font-size:600px; opacity:0.012;
  top:50%; left:50%; transform:translate(-50%,-50%);
  color:var(--pink); pointer-events:none; user-select:none;
  font-family:serif; line-height:1;
}
.booking-inner { position:relative; z-index:1; max-width:720px; margin:0 auto; }
.booking-inner h2 { font-size:clamp(3rem,7vw,6rem); margin-bottom:20px; }
.booking-inner p { color:rgba(240,234,234,0.5); font-size:1rem; line-height:1.9; margin-bottom:52px; }
.booking-note {
  margin-top:40px; font-size:0.72rem; letter-spacing:1px;
  color:rgba(240,234,234,0.25); display:flex; align-items:center;
  justify-content:center; gap:8px;
}
.booking-note::before { content:'📍'; }

/* FAQ */
.faq-wrap { margin-top:64px; max-width:800px; }
.faq-item { border-bottom:1px solid var(--border); }
.faq-q {
  padding:28px 0; font-family:'Playfair Display',serif;
  font-size:1.05rem; color:var(--white); cursor:pointer;
  display:flex; justify-content:space-between; align-items:center;
  transition:color 0.2s;
}
.faq-q:hover { color:var(--pink); }
.faq-icon { color:var(--pink); font-size:1.2rem; transition:transform 0.3s; }
.faq-a { color:var(--muted); font-size:0.87rem; line-height:1.9; padding:0 0 24px; display:none; }
.faq-item.open .faq-a { display:block; }
.faq-item.open .faq-icon { transform:rotate(45deg); }

/* FOOTER */
footer {
  background:var(--charcoal);
  border-top:1px solid rgba(255,26,110,0.12);
  padding:80px 80px 48px;
}
.footer-top { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:60px; margin-bottom:60px; }
.footer-brand {}
.footer-logo-text {
  font-family:'Bebas Neue',sans-serif; font-size:2rem;
  letter-spacing:5px; color:var(--white); margin-bottom:12px; display:block;
}
.footer-logo-text span { color:var(--pink); }
.footer-desc { color:var(--muted); font-size:0.82rem; line-height:1.8; margin-bottom:20px; }
.footer-badges-sm { display:flex; gap:8px; flex-wrap:wrap; }
.fb { font-size:0.6rem; letter-spacing:2px; text-transform:uppercase; padding:5px 12px; border-radius:100px; border:1px solid rgba(57,255,20,0.2); color:var(--neon-green); background:rgba(57,255,20,0.04); }
.footer-col h4 { font-family:'Bebas Neue',sans-serif; font-size:1rem; letter-spacing:3px; color:var(--chrome); margin-bottom:20px; }
.footer-col ul { list-style:none; }
.footer-col ul li { margin-bottom:12px; }
.footer-col ul a { color:var(--muted); text-decoration:none; font-size:0.8rem; transition:color 0.2s; }
.footer-col ul a:hover { color:var(--pink); }
.footer-bottom {
  display:flex; justify-content:space-between; align-items:center;
  border-top:1px solid var(--border); padding-top:32px; flex-wrap:wrap; gap:16px;
}
.footer-copy { color:rgba(102,102,102,0.5); font-size:0.7rem; letter-spacing:1px; }
.footer-ig { color:var(--pink); font-size:0.7rem; letter-spacing:2px; text-decoration:none; text-transform:uppercase; }
.footer-ig:hover { color:var(--pink-glow); }

/* SCROLL FADE */
.reveal { opacity:0; transform:translateY(40px); transition:opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.reveal.in { opacity:1; transform:translateY(0); }
.reveal.delay-1 { transition-delay:0.1s; }
.reveal.delay-2 { transition-delay:0.2s; }
.reveal.delay-3 { transition-delay:0.3s; }

/* RESPONSIVE */
@media(max-width:900px) {
  .hero { padding:0 28px 80px; }
  .section { padding:80px 28px; }
  .about-grid { grid-template-columns:1fr; gap:48px; }
  .services-grid { grid-template-columns:1fr 1fr; }
  .masonry { columns:2; }
  .testi-grid { grid-template-columns:1fr; }
  .footer-top { grid-template-columns:1fr 1fr; gap:40px; }
  nav { padding:0 24px; }
  .nav-links { display:none; }
  .booking-section { padding:100px 28px; }
  footer { padding:60px 28px 40px; }
}
@media(max-width:600px) {
  .masonry { columns:1; }
  .services-grid { grid-template-columns:1fr; }
  .stats-grid { grid-template-columns:1fr 1fr; }
  .footer-top { grid-template-columns:1fr; }
}
</style>
</head>
